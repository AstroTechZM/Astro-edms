#: apps.py:13 settings.py:8
msgid "Auto administrator"
msgstr "自動管理員"

#: auth/allauth.py:51
msgid ""
"Welcome Admin! You have been given super user privileges. Use them with "
"caution."
msgstr "歡迎管理員！您已被授予超級使用者權限，請謹慎使用。"

#: models.py:13
msgid "Account"
msgstr "帳號"

#: models.py:16
msgid "Password"
msgstr "密碼"

#: models.py:20
msgid "Password hash"
msgstr "密碼雜湊值"

#: models.py:26
msgid "Autoadmin properties"
msgstr "自動管理的屬性"

#: settings.py:13
msgid "Sets the email of the automatically created super user account."
msgstr "設定自動建立之超級使用者帳號的電子郵件。"

#: settings.py:19
msgid ""
"The password of the automatically created super user account. If it is equal"
" to None, the password is randomly generated."
msgstr "自動建立之超級使用者帳號的密碼。若為「空」，則隨機產生密碼。"

#: settings.py:26
msgid "The username of the automatically created super user account."
msgstr "自動建立之超級使用者帳號的使用者名稱。"

#: templates/autoadmin/credentials.html:13
msgid "Automatic credentials"
msgstr "自动凭证"

#: templates/autoadmin/credentials.html:17
#, python-format
msgid ""
"You have just finished installing <strong>%(project_title)s</strong>, "
"congratulations!"
msgstr "您剛剛完成了<strong> %(project_title)s </strong>的安裝，恭喜！"

#: templates/autoadmin/credentials.html:18
msgid "Login using the following credentials:"
msgstr "請使用以下憑證登入："

#: templates/autoadmin/credentials.html:20
#, python-format
msgid "Username: <strong>%(account)s</strong>"
msgstr "使用者名稱：<strong>%(account)s</strong>"

#: templates/autoadmin/credentials.html:21
#, python-format
msgid "Email: <strong>%(email)s</strong>"
msgstr "電子郵件：<strong>%(email)s</strong>"

#: templates/autoadmin/credentials.html:22
#, python-format
msgid "Password: <strong>%(password)s</strong>"
msgstr "密碼：<strong>%(password)s</strong>"

#: templates/autoadmin/credentials.html:24
msgid ""
"Be sure to change the password to increase security and to disable this "
"message."
msgstr "請務必修改密碼以提高安全性，並停用此訊息。"
